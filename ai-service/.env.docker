# SLIB AI Service - Docker Environment
# =====================================

# AI Provider: ollama (local LLM)
AI_PROVIDER=ollama

# Ollama Configuration - connects to host machine
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Gemini Configuration (backup)
# Khong commit key that. Dien gia tri that tren VM/GitHub Secrets/.env rieng.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Database (Docker Network)
DATABASE_URL=postgresql://postgres:your_database_password@slib-postgres:5432/slib

# RAG Configuration
SIMILARITY_THRESHOLD=0.75
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_RETRIEVED_CHUNKS=5

# Java Backend (Docker Network)
JAVA_BACKEND_URL=http://slib-backend:8080/slib

# Redis (Docker Network)
REDIS_URL=redis://slib-redis:6379

# Debug
DEBUG=false
