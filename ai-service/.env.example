# ============================================
# SLIB AI Service - Environment Variables Template
# Copy file này thành .env rồi điền giá trị thật
# ============================================

# --- AI PROVIDER ---
AI_PROVIDER=ollama

# --- OLLAMA ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- GEMINI (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- DATABASE ---
DATABASE_URL=postgresql://postgres:your_database_password@localhost:5434/slib

# --- QDRANT ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=slib_knowledge

# --- BACKEND INTEGRATION ---
JAVA_BACKEND_URL=http://localhost:8080/slib
INTERNAL_API_KEY=your_internal_service_key

# --- RAG ---
SIMILARITY_THRESHOLD=0.5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_RETRIEVED_CHUNKS=5

# --- DEBUG ---
DEBUG=false
