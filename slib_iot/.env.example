# ============================================================
# SLIB Gate Configuration
# Copy this file to .env and update the values
# ============================================================

# Backend API base URL (without trailing slash)
SLIB_API_URL=https://api.slibsystem.site

# Gate/Station ID – must match the deviceId registered in admin UI
SLIB_GATE_ID=GATE_01

# API key for backend authentication
SLIB_GATE_API_KEY=SLIB_SECRET_GATE_FPT_123

# Heartbeat interval in seconds (default: 30)
SLIB_HEARTBEAT_INTERVAL=30
