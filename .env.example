# ============================================
# SLIB - Environment Variables Template
# Copy file này thành .env và điền giá trị thật
# ============================================

# --- DATABASE ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=slib

# --- MONGODB ---
MONGO_USER=slib
MONGO_PASSWORD=your_mongo_password

# --- JWT ---
JWT_SECRET=your_jwt_secret_at_least_32_bytes

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=your_google_client_id

# --- FIREBASE PUSH ---
# Host directory containing firebase-service-account.json used by docker-compose
FIREBASE_SECRETS_DIR=/absolute/path/to/secrets

# --- GATE SERVICE (HCE) ---
GATE_SECRET=your_gate_secret

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
